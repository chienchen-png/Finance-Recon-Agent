{
  "_description": "回款提成核对规则 — 可配置的核对逻辑",
  "_schema": "2.0",
  "matching": {
    "strategy": "three_level",
    "levels": [
      {"name": "合同编号", "type": "exact", "weight": 1},
      {"name": "销售人员", "type": "fuzzy", "weight": 0.8},
      {"name": "客户编码", "type": "exact", "weight": 1}
    ],
    "fallback_strategy": "person_customer",
    "fallback_description": "合同编号未匹配时，降级用（人员+客户）复合键查找目标行；标记为[降级匹配]"
  },
  "diff_grading": {
    "A1": {
      "description": "汇总表为空，季度分表有数据",
      "action": "自动填充",
      "conditions": ["target_cell is null or 0", "source_cell > 0", "contract_match = true"]
    },
    "A2": {
      "description": "金额差异 ≤ 1.0 元且人员+客户均一致",
      "action": "自动修正",
      "conditions": ["contract_match = true", "person_match = true", "customer_match = true", "0 < abs(target - source) <= 1.0"]
    },
    "B": {
      "description": "人员/客户不一致 或 金额差异 > 1.0 元待确认",
      "action": "确认后修正",
      "conditions": ["person_match = false", "或 customer_match = false", "或 abs(target - source) > 1.0"]
    },
    "C": {
      "description": "依据独有（目标无此合同）或无法自动判断",
      "action": "人工复核",
      "conditions": ["contract_not_found", "或 fallback 无法判断"]
    }
  },
  "amount_tolerance": 0.01,
  "auto_fix_threshold": 1.0,
  "rounding_strategy": "group_first",
  "rounding_description": "group_first: 先 round(x,2) 再 sum；total_first: 先 sum 再 round(x,2)",
  "reverse_verification": {
    "enabled": true,
    "description": "修正后自动用源季度分表数据回算校验最终汇总表"
  },
  "last_confirmed": {
    "by": "",
    "at": "",
    "quarter": ""
  }
}
